---
import HomePage from '../../components/home/HomePage.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Mar y Cielo',
  alternateName: 'La Casa Que Canta restaurant',
  url: 'https://marycielo.mx/es/',
  image: 'https://marycielo.mx/wp-content/uploads/2023/07/marycielo_3_home.webp',
  servesCuisine: ['Mexican', 'Mediterranean', 'Seafood'],
  keywords:
    'La Casa Que Canta restaurant, Mar y Cielo La Casa Que Canta, La Casa Que Canta dining experience, boutique hotel restaurant Zihuatanejo, luxury hotel restaurant Zihuatanejo, seaside dining experience',
  priceRange: '$$',
  telephone: '+52 755 555 7030',
  email: 'sales.reservations@lacasaquecanta.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Camino Escenico Playa La Ropa S / N, La Ropa Beach',
    addressLocality: 'Zihuatanejo',
    addressRegion: 'Guerrero',
    postalCode: '40880',
    addressCountry: 'MX',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 17.635327,
    longitude: -101.5498233,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '18:00',
      closes: '22:30',
    },
  ],
};
---
<SiteLayout
  title="Mar y Cielo | Restaurante La Casa Que Canta Zihuatanejo"
  description="Mar y Cielo en La Casa Que Canta ofrece una experiencia gastronómica de hotel boutique en Zihuatanejo con mariscos frescos del Pacífico."
  lang="es"
  alternateEn="/"
  alternateEs="/es/"
  keywords="La Casa Que Canta restaurant, Mar y Cielo La Casa Que Canta, La Casa Que Canta dining experience, boutique hotel restaurant Zihuatanejo, luxury hotel restaurant Zihuatanejo, seaside dining experience, boutique hotel dining experience, exclusive hotel restaurant Zihuatanejo, hotel guest dining experience"
  structuredData={restaurantSchema}
>
  <HomePage lang="es" />
</SiteLayout>
