---
import HomePage from '../../components/home/HomePage.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Mar y Cielo',
  url: 'https://marycielo.mx/es/contact/',
  mainEntity: {
    '@type': 'Restaurant',
    name: 'Mar y Cielo',
    telephone: '+52 755 555 7030',
    email: 'sales.reservations@lacasaquecanta.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Camino Escenico Playa La Ropa S / N, La Ropa Beach',
      addressLocality: 'Zihuatanejo',
      addressRegion: 'Guerrero',
      postalCode: '40880',
      addressCountry: 'MX',
    },
  },
};
---
<SiteLayout
  title="Contact & Reservations | Mar y Cielo Zihuatanejo"
  description="Contact Mar y Cielo for reservations, location details and dinner service at La Ropa Beach in Zihuatanejo, Guerrero."
  lang="es"
  image="/wp-content/uploads/2023/07/marycielo_3_home.webp"
  structuredData={contactSchema}
>
  <HomePage variant="contact" />
</SiteLayout>
