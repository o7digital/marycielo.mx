---
import HomePage from '../../components/home/HomePage.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Mar y Cielo',
  url: 'https://marycielo.mx/es/contact/',
  mainEntity: {
    '@type': 'Restaurant',
    name: 'Mar y Cielo',
    alternateName: 'La Casa Que Canta dining experience',
    telephone: '+52 755 555 7030',
    email: 'sales.reservations@lacasaquecanta.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Camino Escenico Playa La Ropa S / N, La Ropa Beach',
      addressLocality: 'Zihuatanejo',
      addressRegion: 'Guerrero',
      postalCode: '40880',
      addressCountry: 'MX',
    },
  },
};
---
<SiteLayout
  title="Dinner at Playa La Ropa | Mar y Cielo Reservations"
  description="Reserve lunch or dinner at Playa La Ropa with Mar y Cielo, an oceanfront dining experience with bay views at La Casa Que Canta in Zihuatanejo."
  lang="es"
  image="/wp-content/uploads/2023/07/marycielo_3_home.webp"
  keywords="breakfast at La Casa Que Canta, lunch at La Casa Que Canta, dinner at La Casa Que Canta, oceanfront breakfast Zihuatanejo, oceanfront lunch Zihuatanejo, oceanfront dinner Zihuatanejo, romantic dinner in Zihuatanejo, restaurant with bay view Zihuatanejo, boutique hotel breakfast Zihuatanejo, lunch at Playa La Ropa, dinner at Playa La Ropa, romantic dining experience La Casa Que Canta"
  structuredData={contactSchema}
>
  <HomePage variant="contact" />
</SiteLayout>
