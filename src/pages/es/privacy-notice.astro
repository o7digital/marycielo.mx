---
import PrivacyNoticeCard from '../../components/PrivacyNoticeCard.astro';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Privacy Notice - marycielo.mx</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Jost:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <PrivacyNoticeCard />
  </body>
</html>

<style>
  :root {
    --primary: #dd5903;
    --secondary: #033a58;
    --card: rgb(255 255 255 / 92%);
    --text: #163042;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: 'Jost', sans-serif;
    color: var(--text);
    background:
      linear-gradient(rgb(3 58 88 / 42%), rgb(3 58 88 / 72%)),
      url('/wp-content/uploads/2023/03/marycielo_home_08.jpg') center / cover no-repeat;
    display: grid;
    place-items: center;
    padding: 24px;
  }

  :global(main) {
    width: min(680px, 100%);
    background: var(--card);
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 20px 60px rgb(0 0 0 / 20%);
    backdrop-filter: blur(10px);
  }

  :global(img) {
    display: block;
    width: 120px;
    margin: 0 auto 20px;
  }

  :global(h1) {
    margin: 0 0 12px;
    font-family: 'Cinzel', serif;
    color: var(--secondary);
    font-size: clamp(2rem, 4vw, 2.8rem);
    text-align: center;
  }

  :global(p) {
    margin: 0 0 14px;
    font-size: 1.05rem;
    line-height: 1.7;
    text-align: center;
  }

  :global(.actions) {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  :global(a.button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 170px;
    padding: 14px 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  :global(a.button:hover) {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  :global(a.button.primary) {
    background: var(--primary);
    color: #fff;
  }

  :global(a.button.secondary) {
    background: transparent;
    color: var(--secondary);
    border: 1px solid rgb(3 58 88 / 20%);
  }
</style>
