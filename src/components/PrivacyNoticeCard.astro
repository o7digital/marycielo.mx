---
const sections = [
  {
    title: '1. Data Collection',
    body: [
      'We may collect personal information through our website, reservation tools, contact forms, social media channels, direct guest interactions, and service requests related to Mar y Cielo and La Casa Que Canta.',
      'This information may include your name, address, email, phone number, reservation details, payment and billing information, nationality, identification or tax details when required, preferences, comments, and any information you voluntarily share to help us provide a better service.',
    ],
  },
  {
    title: '2. Use of Personal and Sensitive Information',
    body: [
      'We use personal data to provide requested services, manage reservations, process payments and refunds, respond to inquiries, improve our guest experience, maintain service quality, and communicate relevant updates or promotions when permitted.',
      'Sensitive information, when voluntarily provided, is used only when necessary to deliver the requested service or respond to a specific guest need.',
    ],
  },
  {
    title: '3. Data Transfers',
    body: [
      'Your information may be shared with service providers that support our operations, including reservation systems, payment processors, IT infrastructure providers, professional advisors, medical support in case of emergency, and government or regulatory authorities when legally required.',
      'If you do not object to these transfers, we will understand that you consent to the transfers necessary for the purposes described in this notice.',
    ],
  },
  {
    title: '4. Data Security',
    body: [
      'CASACANTA ZIHUA S.A. de C.V. maintains physical, technical, and administrative safeguards designed to protect personal data against unauthorized access, loss, alteration, disclosure, or misuse.',
      'These measures may include restricted access controls, secure systems, SSL encryption, and operational practices intended to protect guest and client information.',
    ],
  },
  {
    title: '5. ARCO Rights, GDPR and CCPA',
    body: [
      'You may request access to your personal data, correction of inaccurate or outdated data, cancellation or deletion when legally applicable, objection to processing, portability when applicable, and revocation of consent.',
      'To exercise these rights, please contact us at sales.reservations@lacasaquecanta.com or +52 (755) 555 7030. We will respond within the periods established by applicable law.',
    ],
  },
  {
    title: '6. Modifications',
    body: [
      'This Privacy Notice may be updated at any time to reflect legal, operational, or service changes. Updates will be published on marycielo.mx.',
      'Last updated: July 2026.',
    ],
  },
  {
    title: '7. Data Controller Identity and Address',
    body: [
      'CASACANTA ZIHUA S.A. de C.V.',
      'Fiscal address: Montes Urales 720, Floor 1, Office 1-A, Lomas de Chapultepec I Seccion, Miguel Hidalgo, 11000, CDMX, Mexico.',
      'Restaurant and resort address: Camino Escenico Playa La Ropa S / N, La Ropa Beach, 40880 Zihuatanejo, Guerrero, Mexico.',
    ],
  },
];
---

<main class="privacy-page">
  <div class="privacy-watermarks" aria-hidden="true">
    <span class="watermark watermark-one">LA CASA</span>
    <span class="waterline waterline-one"></span>
    <span class="watermark watermark-two">QUE CANTA</span>
    <span class="waterline waterline-two"></span>
    <span class="watermark watermark-three">LA CASA</span>
    <span class="waterline waterline-three"></span>
  </div>

  <section class="privacy-hero" aria-labelledby="privacy-title">
    <a class="water-logo" href="/" aria-label="Mar y Cielo home">
      <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1.png" alt="Mar y Cielo" />
    </a>
    <p class="eyebrow">Mar y Cielo</p>
    <h1 id="privacy-title">Privacy Notice</h1>
    <p class="intro">
      At Mar y Cielo, operated by CASACANTA ZIHUA S.A. de C.V., we value the trust of our guests and clients.
      This notice explains how we collect, use, protect, and manage personal information in accordance with
      applicable privacy laws.
    </p>
  </section>

  <section class="privacy-content" aria-label="Privacy notice details">
    {
      sections.map((section) => (
        <article class="notice-section">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
        </article>
      ))
    }
  </section>

  <section class="privacy-contact" aria-label="Contact details">
    <div>
      <h2>Contact</h2>
      <p>For questions about this notice or your personal data, contact La Casa Que Canta reservations.</p>
    </div>
    <div class="contact-actions">
      <a href="mailto:sales.reservations@lacasaquecanta.com">sales.reservations@lacasaquecanta.com</a>
      <a href="tel:+527555557030">+52 755 555 7030</a>
      <a href="/">Back to Home</a>
    </div>
  </section>
</main>

<style>
  .privacy-page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    color: var(--ink);
    background:
      linear-gradient(rgb(248 244 237 / 90%), rgb(248 244 237 / 95%)),
      url('/wp-content/uploads/2022/05/fondo_menu.jpg') center / cover fixed;
  }

  .privacy-page > section {
    position: relative;
    z-index: 1;
  }

  .privacy-watermarks {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .watermark,
  .waterline {
    position: absolute;
    display: block;
    opacity: 0.055;
    transform: rotate(-2deg);
  }

  .watermark {
    color: #22372f;
    font-family: var(--title-font);
    font-size: clamp(5.8rem, 15vw, 16rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    white-space: nowrap;
    animation: watermarkDrift 18s ease-in-out infinite alternate;
  }

  .watermark-one {
    top: 21%;
    left: 9%;
  }

  .watermark-two {
    top: 45%;
    left: 9%;
    animation-delay: -5s;
  }

  .watermark-three {
    top: 70%;
    right: -20%;
    animation-delay: -9s;
  }

  .waterline {
    width: min(70vw, 1380px);
    height: 34px;
    border-bottom: 12px solid currentColor;
    border-radius: 0 0 50% 50%;
    color: #22372f;
    animation: waterlineDrift 20s ease-in-out infinite alternate;
  }

  .waterline-one {
    top: 33%;
    left: 7%;
  }

  .waterline-two {
    top: 58%;
    right: 4%;
    animation-delay: -7s;
  }

  .waterline-three {
    top: 82%;
    left: 12%;
    animation-delay: -11s;
  }

  .privacy-hero {
    display: grid;
    justify-items: center;
    padding: clamp(58px, 8vw, 112px) 24px clamp(34px, 5vw, 72px);
    text-align: center;
  }

  .water-logo {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: clamp(132px, 18vw, 210px);
    aspect-ratio: 1;
    margin-bottom: 24px;
    border-radius: 999px;
    overflow: hidden;
    background:
      radial-gradient(circle at 35% 25%, rgb(255 255 255 / 72%), transparent 28%),
      radial-gradient(circle at 70% 75%, rgb(3 58 88 / 26%), transparent 34%),
      linear-gradient(135deg, rgb(160 202 218 / 55%), rgb(255 255 255 / 18), rgb(3 58 88 / 34%));
    box-shadow:
      0 28px 70px rgb(3 58 88 / 18%),
      inset 0 0 36px rgb(255 255 255 / 52%);
  }

  .water-logo::before,
  .water-logo::after {
    content: '';
    position: absolute;
    inset: -18%;
    border-radius: 42% 58% 48% 52%;
    background:
      linear-gradient(110deg, transparent 26%, rgb(255 255 255 / 32%) 44%, transparent 62%),
      repeating-radial-gradient(circle at 50% 50%, rgb(255 255 255 / 20%) 0 2px, transparent 3px 18px);
    animation: waterLeaf 9s linear infinite;
  }

  .water-logo::after {
    animation-duration: 13s;
    animation-direction: reverse;
    opacity: 0.65;
  }

  .water-logo img {
    position: relative;
    z-index: 1;
    width: 78%;
    filter: drop-shadow(0 10px 18px rgb(3 58 88 / 20%));
  }

  .eyebrow {
    margin: 0 0 8px;
    color: var(--orange);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
  }

  h1,
  h2 {
    font-family: var(--title-font);
    color: var(--blue);
    font-weight: 500;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.25rem);
    line-height: 1.02;
  }

  .intro {
    width: min(760px, 100%);
    margin: 24px auto 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  .privacy-content {
    width: min(980px, calc(100% - 40px));
    margin: 0 auto;
    padding: 0 0 clamp(44px, 6vw, 76px);
  }

  .notice-section {
    padding: 30px 0;
    border-top: 1px solid rgb(3 58 88 / 16%);
  }

  .notice-section h2 {
    margin: 0 0 14px;
    font-size: clamp(1.2rem, 2.2vw, 1.65rem);
    line-height: 1.25;
  }

  .notice-section p {
    margin: 0 0 13px;
    color: #263f4e;
    font-size: 18px;
    line-height: 1.72;
  }

  .notice-section p:last-child {
    margin-bottom: 0;
  }

  .privacy-contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 28px;
    align-items: center;
    padding: clamp(36px, 5vw, 58px) clamp(24px, 7vw, 90px);
    color: var(--white);
    background:
      linear-gradient(rgb(20 49 79 / 91%), rgb(20 49 79 / 91%)),
      url('/wp-content/uploads/2023/03/marycielo_home_04.jpg') center / cover no-repeat;
  }

  .privacy-contact h2 {
    margin: 0 0 12px;
    color: var(--white);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
  }

  .privacy-contact p {
    max-width: 620px;
    margin: 0;
    color: rgb(255 255 255 / 78%);
    font-size: 18px;
    line-height: 1.65;
  }

  .contact-actions {
    display: grid;
    gap: 12px;
  }

  .contact-actions a {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(255 255 255 / 52%);
    padding: 12px 16px;
    color: var(--white);
    text-align: center;
    text-decoration: none;
  }

  @keyframes waterLeaf {
    from {
      transform: rotate(0deg) scale(1);
    }

    to {
      transform: rotate(360deg) scale(1.04);
    }
  }

  @keyframes watermarkDrift {
    from {
      transform: translate3d(-18px, 0, 0) rotate(-2deg);
    }

    to {
      transform: translate3d(26px, 10px, 0) rotate(-1deg);
    }
  }

  @keyframes waterlineDrift {
    from {
      transform: translate3d(18px, 0, 0) rotate(-1deg);
    }

    to {
      transform: translate3d(-22px, 8px, 0) rotate(1deg);
    }
  }

  @media (max-width: 720px) {
    .privacy-page {
      background-attachment: scroll;
    }

    .privacy-content {
      width: min(100% - 32px, 980px);
    }

    .watermark {
      font-size: clamp(4.2rem, 22vw, 7.8rem);
      letter-spacing: 0.11em;
      opacity: 0.045;
    }

    .watermark-one,
    .watermark-two {
      left: -6%;
    }

    .watermark-three {
      right: -70%;
    }

    .waterline {
      width: 120vw;
      opacity: 0.045;
    }

    .notice-section {
      padding: 24px 0;
    }

    .notice-section p {
      font-size: 16px;
    }

    .privacy-contact {
      grid-template-columns: 1fr;
    }
  }
</style>
