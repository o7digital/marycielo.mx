---
const menuItems = [
  {
    name: 'White ceviche',
    detail: 'Ceviche blanco',
    usd: '$12 usd',
    mxn: '$220 mxn',
  },
  {
    name: 'Mango ceviche',
    detail: 'Ceviche de mango',
    usd: '$12 usd',
    mxn: '$220 mxn',
  },
  {
    name: 'Avocado stuffed with Pacific seafood',
    detail: 'Aguacate relleno de mariscos del Pacifico',
    usd: '$10 usd',
    mxn: '$195 mxn',
  },
  {
    name: 'Sashimi, tuna and sea bass and Pacific shrimp with soy sauce and ginger dressing',
    detail: 'Sashimi, atun, robalo y camaron del pacifico con aderezo de salsa de soya y jengibre',
    usd: '$10 usd',
    mxn: '$205 mxn',
  },
];

const mapUrl =
  'https://www.google.com.mx/maps/place/La+Casa+Que+Canta/@17.635327,-101.5520173,17z/data=!3m1!4b1!4m9!3m8!1s0x8434773fd15b8acf:0x3a5d08d68ce6d8a7!5m2!4m1!1i2!8m2!3d17.635327!4d-101.5498233!16s%2Fg%2F1tnms17p';
---
<div class="site-shell">
  <header class="site-header" aria-label="Primary navigation">
    <a class="menu-link" href="#selected-menus">
      <span class="hamburger" aria-hidden="true"></span>
      <span>Menu</span>
    </a>

    <a class="brand" href="/" aria-label="Mar y Cielo home">
      <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1-370x370.png" alt="Mar y Cielo" />
    </a>

    <a class="header-button" href="#reservation">Find a Table</a>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true">
        <span class="hero-slide slide-one"></span>
        <span class="hero-slide slide-two"></span>
        <span class="hero-slide slide-three"></span>
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p id="hero-title">Our sea food fresh daily from Zihuatanejo's coast</p>
        <h1>Traditional Mexican recipes | Mediterranean dishes</h1>
      </div>
    </section>

    <section id="selected-menus" class="selected-menu" aria-labelledby="menu-title">
      <div class="menu-panel">
        <p class="eyebrow">Recommendations</p>
        <h2 id="menu-title">Selected Menus</h2>
        <div class="menu-list">
          {
            menuItems.map((item) => (
              <article class="menu-item">
                <div class="menu-row">
                  <h3>{item.name}</h3>
                  <span class="menu-line" aria-hidden="true"></span>
                  <span class="price">{item.usd}</span>
                  <span class="price">{item.mxn}</span>
                </div>
                <p>{item.detail}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="image-break" aria-label="Restaurant view"></section>
  </main>

  <footer id="colophon" class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/">
          <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1.png" alt="Mar y Cielo" />
        </a>
        <p>We take pride on our daily catch of sea food</p>
      </div>

      <section class="footer-block" aria-labelledby="location-title">
        <h2 id="location-title">Location</h2>
        <p>Camino Escenico<br />Playa La Ropa S / N,<br />La Ropa Beach, 40880<br />Zihuatanejo, Guerrero, Mexico</p>
        <a class="underline-link" href={mapUrl} target="_blank" rel="noopener">View On Map</a>
      </section>

      <section class="footer-block" aria-labelledby="hours-title">
        <h2 id="hours-title">Opening Hours</h2>
        <p><strong>Dinner</strong><br />From 18:00pm to 22:30pm</p>
        <img class="seal" src="/wp-content/uploads/2022/04/698eb08458461ec7b162801c6e46fc53.webp" alt="" />
      </section>

      <section id="reservation" class="footer-block" aria-labelledby="contact-title">
        <h2 id="contact-title">Contact us</h2>
        <a class="outline-button" href="mailto:concierge@lacasaquecanta.com">Email Us</a>
        <a class="outline-button" href="tel:+527555557030">Phone: + 52 755 555 7030</a>
        <a class="solid-button" href="https://www.opentable.com/restref/client/?rid=1261543&restref=1261543&lang=en-US&domain=com" target="_blank" rel="noopener">
          Make a reservation
        </a>
        <nav class="social-links" aria-label="Social links">
          <a href="https://www.facebook.com">Facebook</a>
          <a href="https://www.instagram.com">Instagram</a>
        </nav>
      </section>
    </div>

    <div class="footer-bottom">
      <p>© Copyright Mar y Cielo. | Design by o7Digital <a href="/es/privacy-notice/">Privacy Notice</a></p>
    </div>
  </footer>
</div>

<style>
  .site-shell {
    min-width: 320px;
    overflow-x: hidden;
  }

  .site-header {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 112px;
    padding: 22px clamp(22px, 4vw, 70px);
    color: var(--white);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .brand img {
    width: clamp(92px, 11vw, 150px);
    display: block;
  }

  .menu-link,
  .header-button,
  .outline-button,
  .solid-button,
  .underline-link {
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0;
    font-size: 13px;
    font-weight: 500;
  }

  .menu-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .hamburger::before {
    top: -7px;
  }

  .hamburger::after {
    top: 7px;
  }

  .header-button {
    justify-self: end;
    border: 1px solid rgb(255 255 255 / 76%);
    padding: 15px 26px;
    color: var(--white);
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    isolation: isolate;
    text-align: center;
    color: var(--white);
  }

  .hero-media,
  .hero-slide,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    overflow: hidden;
    z-index: -3;
    background: var(--blue-dark);
  }

  .hero-slide {
    opacity: 0;
    background-position: bottom center;
    background-size: cover;
    animation: heroFade 18s infinite;
    transform: scale(1.04);
  }

  .slide-one {
    background-image: url('/wp-content/uploads/2023/03/marycielo_home_04.jpg');
  }

  .slide-two {
    background-image: url('/wp-content/uploads/2023/03/marycielo_home_05.jpg');
    animation-delay: 6s;
  }

  .slide-three {
    background-image: url('/wp-content/uploads/2023/03/marycielo_home_08.jpg');
    animation-delay: 12s;
  }

  .hero-overlay {
    z-index: -1;
    background: rgb(0 0 0 / 42%);
  }

  .hero-content {
    width: min(1040px, calc(100% - 44px));
    padding-top: 90px;
  }

  .hero p,
  .eyebrow {
    margin: 0;
    font-family: var(--title-font);
    font-weight: 500;
  }

  .hero p {
    font-size: clamp(2rem, 5.4vw, 3.8rem);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 20px 0 0;
    font-size: 18px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .selected-menu {
    min-height: 700px;
    margin: 40px 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 1fr);
    align-items: stretch;
    background: url('/wp-content/uploads/2023/03/marycielo_home_05.jpg') bottom center / cover no-repeat;
  }

  .menu-panel {
    grid-column: 2;
    align-self: center;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: rgb(255 255 255 / 95%);
    padding: clamp(34px, 5vw, 68px) clamp(28px, 4vw, 60px);
  }

  .eyebrow {
    color: var(--blue);
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.18;
  }

  .menu-panel h2 {
    margin: 10px 0 34px;
    color: var(--blue);
    font-size: 15px;
    font-weight: 500;
    text-align: center;
    text-transform: uppercase;
  }

  .menu-list {
    display: grid;
    gap: 24px;
  }

  .menu-row {
    display: grid;
    grid-template-columns: auto minmax(24px, 1fr) auto auto;
    align-items: baseline;
    gap: 10px;
  }

  .menu-item h3 {
    margin: 0;
    max-width: 270px;
    font-family: var(--title-font);
    color: var(--ink);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
  }

  .menu-line {
    border-bottom: 1px solid rgb(10 37 62 / 28%);
    transform: translateY(-4px);
  }

  .price {
    color: var(--orange);
    font-size: 14px;
    white-space: nowrap;
  }

  .menu-item p {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.5;
  }

  .image-break {
    min-height: 700px;
    background: url('/wp-content/uploads/2023/03/marycielo_home_08.jpg') center / cover no-repeat;
  }

  .site-footer {
    color: var(--white);
    background:
      linear-gradient(rgb(20 49 79 / 90%), rgb(20 49 79 / 90%)),
      url('/wp-content/uploads/2023/03/marycielo_home_04.jpg') center / cover no-repeat;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.1fr 1.25fr 1fr 1fr;
    gap: clamp(28px, 4vw, 56px);
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px clamp(24px, 5vw, 70px) 28px;
  }

  .footer-brand img {
    width: 156px;
  }

  .footer-brand p,
  .footer-block p,
  .footer-bottom {
    font-size: 15px;
    line-height: 1.55;
  }

  .footer-block h2 {
    margin: 10px 0 16px;
    font-family: var(--title-font);
    font-size: 18px;
    font-weight: 500;
  }

  .footer-block p {
    margin: 0 0 16px;
  }

  .underline-link {
    display: inline-flex;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
  }

  .seal {
    width: 90px;
    margin-top: 8px;
  }

  .outline-button,
  .solid-button {
    display: flex;
    width: 100%;
    min-height: 45px;
    align-items: center;
    justify-content: center;
    margin: 0 0 12px;
    padding: 12px 14px;
    text-align: center;
  }

  .outline-button {
    border: 1px solid rgb(255 255 255 / 76%);
  }

  .solid-button {
    background: var(--white);
    color: var(--blue);
  }

  .social-links {
    display: flex;
    gap: 18px;
    margin-top: 18px;
    font-size: 14px;
  }

  .footer-bottom {
    max-width: 1600px;
    margin: 0 auto;
    border-top: 1px solid rgb(255 255 255 / 13%);
    padding: 14px clamp(24px, 5vw, 70px);
    color: #cbcbcb;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-bottom a {
    margin-left: 12px;
  }

  @keyframes heroFade {
    0% {
      opacity: 0;
      transform: scale(1.04);
    }
    8%,
    33% {
      opacity: 1;
    }
    45%,
    100% {
      opacity: 0;
      transform: scale(1.11);
    }
  }

  @media (max-width: 1024px) {
    .selected-menu {
      grid-template-columns: minmax(20%, 1fr) minmax(440px, 70%);
    }

    .footer-inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding-top: 150px;
    }
  }

  @media (max-width: 767px) {
    .site-header {
      grid-template-columns: 1fr auto;
      min-height: 90px;
      padding: 18px 24px;
    }

    .brand {
      justify-self: start;
      grid-column: 1;
      grid-row: 1;
    }

    .menu-link {
      justify-self: end;
      grid-column: 2;
      grid-row: 1;
    }

    .header-button {
      display: none;
    }

    .brand img {
      width: 86px;
    }

    .hero {
      min-height: 574px;
    }

    .hero-content {
      padding: 94px 6px 0;
    }

    .hero p {
      font-size: 28px;
    }

    .hero h1 {
      margin-top: 31px;
      font-size: 18px;
      line-height: 1.5;
    }

    .selected-menu {
      min-height: 0;
      margin: 0;
      grid-template-columns: 1fr;
      padding: 320px 18px 40px;
    }

    .menu-panel {
      grid-column: 1;
      min-height: auto;
      padding: 34px 24px;
    }

    .eyebrow {
      font-size: 31px;
    }

    .menu-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .menu-line {
      display: none;
    }

    .menu-item h3 {
      max-width: none;
    }

    .image-break {
      min-height: 420px;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      padding-top: 90px;
    }

    .footer-bottom {
      text-align: center;
    }

    .footer-bottom a {
      display: inline-block;
      margin: 8px 0 0;
    }
  }
</style>
