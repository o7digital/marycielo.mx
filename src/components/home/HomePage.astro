---
const menuItemsByLang = {
  en: [
    {
      name: 'White ceviche',
      detail: 'Ceviche blanco',
      usd: '$12 usd',
      mxn: '$220 mxn',
    },
    {
      name: 'Mango ceviche',
      detail: 'Ceviche de mango',
      usd: '$12 usd',
      mxn: '$220 mxn',
    },
    {
      name: 'Avocado stuffed with Pacific seafood',
      detail: 'Aguacate relleno de mariscos del Pacífico',
      usd: '$10 usd',
      mxn: '$195 mxn',
    },
    {
      name: 'Sashimi, tuna and sea bass and Pacific shrimp with soy sauce and ginger dressing',
      detail: 'Sashimi, atún, róbalo y camarón del pacífico con aderezo de salsa de soya y jengibre',
      usd: '$10 usd',
      mxn: '$205 mxn',
    },
  ],
  es: [
    {
      name: 'Ceviche blanco',
      detail: 'White ceviche',
      usd: '$12 usd',
      mxn: '$220 mxn',
    },
    {
      name: 'Ceviche de mango',
      detail: 'Mango ceviche',
      usd: '$12 usd',
      mxn: '$220 mxn',
    },
    {
      name: 'Aguacate relleno de mariscos del Pacífico',
      detail: 'Avocado stuffed with Pacific seafood',
      usd: '$10 usd',
      mxn: '$195 mxn',
    },
    {
      name: 'Sashimi de atún, róbalo y camarón del Pacífico con aderezo de soya y jengibre',
      detail: 'Tuna, sea bass and Pacific shrimp sashimi',
      usd: '$10 usd',
      mxn: '$205 mxn',
    },
  ],
};

interface Props {
  variant?: 'home' | 'menu' | 'contact';
  lang?: 'en' | 'es';
}

const { variant = 'home', lang = 'en' } = Astro.props;
const showHero = variant === 'home';
const showMenu = variant === 'home' || variant === 'menu';
const showImageBreak = variant === 'home';
const pageTitleId = `${variant}-page-title`;
const copy = {
  en: {
    menu: 'Menu',
    findTable: 'Find a Table',
    heroKicker: "Our sea food fresh daily from Zihuatanejo's coast",
    heroTitle: 'Traditional Mexican recipes | Mediterranean dishes',
    pageMenuTitle: 'Selected Menus',
    pageContactTitle: 'Contact us',
    recommendations: 'Recommendations',
    selectedMenus: 'Selected Menus',
    contactUs: 'Contact us',
    location: 'Location',
    viewMap: 'View On Map',
    reservations: 'Reservations',
    dinnerHours: 'Dinner from 18:00pm to 22:30pm',
    emailUs: 'Email Us',
    phone: 'Phone: + 52 755 555 7030',
    makeReservation: 'Make a reservation',
    footerCatch: 'We take pride on our daily catch of sea food',
    openingHours: 'Opening Hours',
    dinner: 'Dinner',
    privacy: 'Privacy Notice',
    restaurantView: 'Restaurant view',
  },
  es: {
    menu: 'Menú',
    findTable: 'Reservar',
    heroKicker: 'Mariscos frescos todos los días de la costa de Zihuatanejo',
    heroTitle: 'Recetas mexicanas tradicionales | Platillos mediterráneos',
    pageMenuTitle: 'Menús seleccionados',
    pageContactTitle: 'Contacto',
    recommendations: 'Recomendaciones',
    selectedMenus: 'Menús seleccionados',
    contactUs: 'Contacto',
    location: 'Ubicación',
    viewMap: 'Ver mapa',
    reservations: 'Reservaciones',
    dinnerHours: 'Cena de 18:00 a 22:30',
    emailUs: 'Enviar email',
    phone: 'Teléfono: + 52 755 555 7030',
    makeReservation: 'Reservar',
    footerCatch: 'Nos enorgullece nuestra pesca fresca del día',
    openingHours: 'Horario',
    dinner: 'Cena',
    privacy: 'Aviso de privacidad',
    restaurantView: 'Vista del restaurante',
  },
}[lang];
const menuItems = menuItemsByLang[lang];
const routeMap = {
  home: { en: '/', es: '/es/' },
  menu: { en: '/a-la-carte-menu/', es: '/es/a-la-carte-menu/' },
  contact: { en: '/contact/', es: '/es/contact/' },
};

const mapUrl =
  'https://www.google.com.mx/maps/place/La+Casa+Que+Canta/@17.635327,-101.5520173,17z/data=!3m1!4b1!4m9!3m8!1s0x8434773fd15b8acf:0x3a5d08d68ce6d8a7!5m2!4m1!1i2!8m2!3d17.635327!4d-101.5498233!16s%2Fg%2F1tnms17p';
const reservationUrl = 'https://www.opentable.com/restref/client/?rid=1261543&restref=1261543&lang=en-US&domain=com';
---
<div class:list={['site-shell', `page-${variant}`]}>
  <header class="site-header" aria-label="Primary navigation">
    <div class="header-left">
      <button class="menu-link" type="button" data-menu-open aria-controls="site-menu" aria-expanded="false">
        <span class="hamburger" aria-hidden="true"></span>
        <span>{copy.menu}</span>
      </button>
      <nav class="language-switch" aria-label="Language switcher">
        {lang === 'en' ? (
          <>
            <a class="is-active" href={routeMap[variant].en} hreflang="en" aria-current="page">EN</a>
            <a href={routeMap[variant].es} hreflang="es-MX">ES</a>
          </>
        ) : (
          <>
            <a class="is-active" href={routeMap[variant].es} hreflang="es-MX" aria-current="page">ES</a>
            <a href={routeMap[variant].en} hreflang="en">EN</a>
          </>
        )}
      </nav>
    </div>

    <a class="brand" href="/" aria-label="Mar y Cielo home">
      <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1-370x370.webp" alt="Mar y Cielo" />
    </a>

    <a class="header-button" href={reservationUrl} target="_blank" rel="noopener">{copy.findTable}</a>
  </header>

  <main>
    {
      showHero && (
        <section class="hero" aria-labelledby="hero-title">
          <div class="hero-media" aria-hidden="true">
            <span class="hero-slide slide-one" />
            <span class="hero-slide slide-two" />
            <span class="hero-slide slide-three" />
            <span class="hero-slide slide-four" />
            <span class="hero-slide slide-five" />
          </div>
          <div class="hero-overlay" />
          <div class="hero-content">
            <p id="hero-title">{copy.heroKicker}</p>
            <h1>{copy.heroTitle}</h1>
          </div>
        </section>
      )
    }

    {
      !showHero && (
        <section class="page-hero" aria-labelledby={pageTitleId}>
          <div>
            <p class="eyebrow">Mar y Cielo</p>
            <h1 id={pageTitleId}>{variant === 'menu' ? copy.pageMenuTitle : copy.pageContactTitle}</h1>
          </div>
        </section>
      )
    }

    {
      showMenu && (
        <section id="selected-menus" class="selected-menu" aria-labelledby="menu-title">
          <div class="menu-panel">
            <p class="eyebrow">{copy.recommendations}</p>
            <h2 id="menu-title">{copy.selectedMenus}</h2>
            <div class="menu-list">
              {menuItems.map((item) => (
                <article class="menu-item">
                  <div class="menu-row">
                    <h3>{item.name}</h3>
                    <span class="menu-line" aria-hidden="true" />
                    <span class="price">{item.usd}</span>
                    <span class="price">{item.mxn}</span>
                  </div>
                  <p>{item.detail}</p>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      showImageBreak && <section class="image-break" aria-label={copy.restaurantView} />
    }

    {
      variant === 'contact' && (
        <section class="contact-panel" aria-labelledby="contact-location-title">
          <div>
            <p class="eyebrow">{copy.location}</p>
            <h2 id="contact-location-title">La Ropa Beach, Zihuatanejo</h2>
            <p>Camino Escenico Playa La Ropa S / N, La Ropa Beach, 40880 Zihuatanejo, Guerrero, Mexico</p>
            <a class="underline-link dark" href={mapUrl} target="_blank" rel="noopener">{copy.viewMap}</a>
          </div>
          <div>
            <p class="eyebrow">{copy.reservations}</p>
            <h2>{copy.dinnerHours}</h2>
            <a class="outline-button dark" href="mailto:sales.reservations@lacasaquecanta.com">{copy.emailUs}</a>
            <a class="outline-button dark" href="tel:+527555557030">{copy.phone}</a>
            <a class="solid-button dark" href={reservationUrl} target="_blank" rel="noopener">
              {copy.makeReservation}
            </a>
          </div>
        </section>
      )
    }
  </main>

  <footer id="colophon" class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/">
          <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1.webp" alt="Mar y Cielo" />
        </a>
        <p>{copy.footerCatch}</p>
      </div>

      <section class="footer-block" aria-labelledby="location-title">
        <h2 id="location-title">{copy.location}</h2>
        <p>Camino Escenico<br />Playa La Ropa S / N,<br />La Ropa Beach, 40880<br />Zihuatanejo, Guerrero, Mexico</p>
        <a class="underline-link" href={mapUrl} target="_blank" rel="noopener">{copy.viewMap}</a>
      </section>

      <section class="footer-block" aria-labelledby="hours-title">
        <h2 id="hours-title">{copy.openingHours}</h2>
        <p><strong>{copy.dinner}</strong><br />{copy.dinnerHours.replace('Dinner from ', 'From ').replace('Cena de ', 'De ')}</p>
        <img class="seal" src="/wp-content/uploads/2022/04/698eb08458461ec7b162801c6e46fc53.webp" alt="" />
      </section>

      <section id="reservation" class="footer-block" aria-labelledby="contact-title">
        <h2 id="contact-title">{copy.contactUs}</h2>
        <a class="outline-button" href="mailto:sales.reservations@lacasaquecanta.com">{copy.emailUs}</a>
        <a class="outline-button" href="tel:+527555557030">{copy.phone}</a>
        <a class="solid-button" href={reservationUrl} target="_blank" rel="noopener">
          {copy.makeReservation}
        </a>
        <nav class="social-links" aria-label="Social links">
          <a href="https://www.facebook.com">Facebook</a>
          <a href="https://www.instagram.com">Instagram</a>
        </nav>
      </section>
    </div>

    <div class="footer-bottom">
      <p>© Copyright Mar y Cielo. | Design by o7Digital <a href={lang === 'es' ? '/es/privacy-notice/' : '/privacy-notice/'}>{copy.privacy}</a></p>
    </div>
  </footer>

  <div id="site-menu" class="menu-overlay" aria-hidden="true">
    <button class="menu-close" type="button" data-menu-close aria-label="Close menu"></button>
    <div class="menu-overlay-image" aria-hidden="true"></div>
    <div class="menu-overlay-panel">
      <a class="overlay-logo" href="/" aria-label="Mar y Cielo home">
        <img src="/wp-content/uploads/2023/03/Logo-Mar-y-Cielo-2023-500x500-1.webp" alt="Mar y Cielo" />
      </a>
      <nav class="overlay-nav" aria-label="Menu navigation">
        <a href={routeMap.menu[lang]} data-menu-close>{copy.menu}</a>
        <a href={routeMap.contact[lang]} data-menu-close>{copy.contactUs}</a>
      </nav>
      <a class="overlay-reservation" href={reservationUrl} target="_blank" rel="noopener" data-menu-close>{copy.makeReservation}</a>
      <address class="overlay-contact">
        <a href={mapUrl} target="_blank" rel="noopener"><span aria-hidden="true">●</span> Camino Escénico Playa La Ropa S / N, La Ropa Beach, 40880 Zihuatanejo, Guerrero, México</a>
        <a href="mailto:concierge@lacasaquecanta.com"><span aria-hidden="true">□</span> concierge@lacasaquecanta.com</a>
        <a href="tel:+52755557030"><span aria-hidden="true">◆</span> + 52 755 55 57030</a>
        <a href="https://api.whatsapp.com/send?phone=5525641838"><span aria-hidden="true">◉</span> 55 2564 1838</a>
      </address>
      <nav class="overlay-social" aria-label="Social links">
        <a href="https://www.facebook.com">f</a>
        <a href="https://www.instagram.com">◎</a>
      </nav>
    </div>
  </div>
</div>

<script>
  const overlay = document.querySelector('[data-astro-cid-zqvhxwan] #site-menu') ?? document.getElementById('site-menu');
  const openButton = document.querySelector('[data-menu-open]');
  const closeButtons = document.querySelectorAll('[data-menu-close]');
  const pageContent = document.querySelectorAll('.site-header, main, .site-footer');

  function setMenu(open) {
    if (!(overlay instanceof HTMLElement) || !(openButton instanceof HTMLElement)) return;
    overlay.classList.toggle('is-open', open);
    overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
    openButton.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.documentElement.classList.toggle('menu-is-open', open);
    pageContent.forEach((element) => {
      if (element instanceof HTMLElement) {
        element.inert = open;
      }
    });
  }

  openButton?.addEventListener('click', () => setMenu(true));
  closeButtons.forEach((button) => button.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenu(false);
  });
</script>

<style>
  .site-shell {
    min-width: 320px;
    overflow-x: hidden;
  }

  .site-header {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 112px;
    padding: 22px clamp(22px, 4vw, 70px);
    color: var(--white);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .brand img {
    width: clamp(92px, 11vw, 150px);
    display: block;
  }

  .header-left {
    display: flex;
    align-items: flex-start;
    gap: 22px;
    justify-self: start;
  }

  .language-switch {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    width: fit-content;
    color: inherit;
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .language-switch a {
    text-decoration: none;
    opacity: 0.72;
  }

  .language-switch a.is-active {
    opacity: 1;
  }

  .language-switch a.is-active::after {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-left: 7px;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: translateY(-2px) rotate(45deg);
  }

  .menu-link,
  .header-button,
  .outline-button,
  .solid-button,
  .underline-link {
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0;
    font-size: 13px;
    font-weight: 500;
  }

  .menu-link {
    display: inline-flex;
    align-items: center;
    gap: 17px;
    width: fit-content;
    color: inherit;
    font-size: 19px;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 35px;
    height: 1px;
    background: currentColor;
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .hamburger::before {
    top: -7px;
  }

  .hamburger::after {
    top: 7px;
  }

  .header-button {
    justify-self: end;
    border: 1px solid rgb(255 255 255 / 76%);
    padding: 15px 26px;
    color: var(--white);
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    isolation: isolate;
    text-align: center;
    color: var(--white);
  }

  .hero-media,
  .hero-slide,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    overflow: hidden;
    z-index: -3;
    background: var(--blue-dark);
  }

  .hero-slide {
    opacity: 0;
    background-position: bottom center;
    background-size: cover;
    animation: heroFade 30s infinite;
    transform: scale(1.04);
  }

  .slide-one {
    background-image: url('/wp-content/uploads/2023/07/marycielo_lcqc_01.jpg');
  }

  .slide-two {
    background-image: url('/wp-content/uploads/2023/07/marycielo_3_home.webp');
    animation-delay: 6s;
  }

  .slide-three {
    background-image: url('/wp-content/uploads/2023/07/marycielo_lcqc_02.jpg');
    animation-delay: 12s;
  }

  .slide-four {
    background-image: url('/wp-content/uploads/2023/03/marycielo_home_04.jpg');
    animation-delay: 18s;
  }

  .slide-five {
    background-image: url('/wp-content/uploads/2023/03/marycielo_home_05.webp');
    animation-delay: 24s;
  }

  .hero-overlay {
    z-index: -1;
    background: rgb(0 0 0 / 42%);
  }

  .hero-content {
    width: min(1040px, calc(100% - 44px));
    padding-top: 90px;
  }

  .hero p,
  .eyebrow {
    margin: 0;
    font-family: var(--title-font);
    font-weight: 500;
  }

  .hero p {
    font-size: clamp(2rem, 5.25vw, 4.05rem);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 20px 0 0;
    font-size: 18px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .selected-menu {
    min-height: 700px;
    margin: 40px 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 1fr);
    align-items: stretch;
    background: url('/wp-content/uploads/2023/03/marycielo_home_05.webp') bottom center / cover no-repeat;
  }

  .page-hero {
    min-height: 420px;
    display: grid;
    place-items: center;
    padding: 128px 24px 72px;
    text-align: center;
    color: var(--white);
    background:
      linear-gradient(rgb(0 0 0 / 42%), rgb(0 0 0 / 48%)),
      url('/wp-content/uploads/2023/07/marycielo_3_home.webp') center / cover no-repeat;
  }

  .page-hero h1,
  .contact-panel h2 {
    margin: 10px 0 0;
    font-family: var(--title-font);
    font-weight: 500;
    text-transform: uppercase;
  }

  .page-hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
  }

  .page-menu .selected-menu {
    margin-top: 0;
  }

  .contact-panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(28px, 5vw, 70px);
    padding: clamp(56px, 8vw, 110px) clamp(24px, 7vw, 90px);
    background:
      linear-gradient(rgb(255 255 255 / 94%), rgb(255 255 255 / 94%)),
      url('/wp-content/uploads/2022/05/fondo_menu.webp') center / cover no-repeat;
  }

  .contact-panel .eyebrow {
    text-align: left;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .contact-panel h2 {
    color: var(--blue);
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    line-height: 1.2;
  }

  .contact-panel p:not(.eyebrow) {
    max-width: 540px;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.7;
  }

  .underline-link.dark {
    color: var(--blue);
  }

  .outline-button.dark,
  .solid-button.dark {
    max-width: 380px;
  }

  .outline-button.dark {
    color: var(--blue);
    border-color: rgb(3 58 88 / 30%);
  }

  .solid-button.dark {
    color: var(--white);
    background: var(--blue);
  }

  .menu-panel {
    grid-column: 2;
    align-self: center;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: rgb(255 255 255 / 95%);
    padding: clamp(34px, 5vw, 68px) clamp(28px, 4vw, 60px);
  }

  .eyebrow {
    color: var(--blue);
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.18;
  }

  .menu-panel h2 {
    margin: 10px 0 34px;
    color: var(--blue);
    font-size: 15px;
    font-weight: 500;
    text-align: center;
    text-transform: uppercase;
  }

  .menu-list {
    display: grid;
    gap: 24px;
  }

  .menu-row {
    display: grid;
    grid-template-columns: auto minmax(24px, 1fr) auto auto;
    align-items: baseline;
    gap: 10px;
  }

  .menu-item h3 {
    margin: 0;
    max-width: 270px;
    font-family: var(--title-font);
    color: var(--ink);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
  }

  .menu-line {
    border-bottom: 1px solid rgb(10 37 62 / 28%);
    transform: translateY(-4px);
  }

  .price {
    color: var(--orange);
    font-size: 14px;
    white-space: nowrap;
  }

  .menu-item p {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.5;
  }

  .image-break {
    min-height: 700px;
    background: url('/wp-content/uploads/2023/03/marycielo_home_08.webp') center / cover no-repeat;
  }

  .site-footer {
    color: var(--white);
    background:
      linear-gradient(rgb(20 49 79 / 90%), rgb(20 49 79 / 90%)),
      url('/wp-content/uploads/2023/03/marycielo_home_04.jpg') center / cover no-repeat;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.1fr 1.25fr 1fr 1fr;
    gap: clamp(28px, 4vw, 56px);
    max-width: 1600px;
    margin: 0 auto;
    padding: 36px clamp(24px, 5vw, 70px) 28px;
  }

  .footer-brand img {
    width: 156px;
  }

  .footer-brand p,
  .footer-block p,
  .footer-bottom {
    font-size: 15px;
    line-height: 1.55;
  }

  .footer-block h2 {
    margin: 10px 0 16px;
    font-family: var(--title-font);
    font-size: 18px;
    font-weight: 500;
  }

  .footer-block p {
    margin: 0 0 16px;
  }

  .underline-link {
    display: inline-flex;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
  }

  .seal {
    width: 90px;
    margin-top: 8px;
  }

  .outline-button,
  .solid-button {
    display: flex;
    width: 100%;
    min-height: 45px;
    align-items: center;
    justify-content: center;
