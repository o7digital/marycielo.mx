---
interface Props {
  title: string;
  href: string;
  label: string;
}

const { title, href, label } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${href}`} />
    <title>{title}</title>
    <script define:vars={{ href }}>location.replace(href);</script>
  </head>
  <body>
    <p><a href={href}>{label}</a></p>
  </body>
</html>
